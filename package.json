{
  "name": "gen-api-types-vsce",
  "displayName": "Gen API Types",
  "description": "在 VS Code 中调用 gen-api-types 生成 API 返回类型。",
  "version": "1.0.0",
  "icon": "images/icon.png",
  "repository": {
    "url": "https://github.com/xuejiangping/gen-api-types-vsce.git"
  },
  "publisher": "your-publisher-name",
  "engines": {
    "vscode": "^1.70.0",
    "node": ">=20.0.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:extension-template.hello",
    "onCommand:extension-template.openWebview",
    "onCommand:gen-api-types.generateApiTypes"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extension-template.hello",
        "title": "Extension Template: Hello"
      },
      {
        "command": "extension-template.openWebview",
        "title": "Extension Template: Open Webview"
      },
      {
        "command": "gen-api-types.generateApiTypes",
        "title": "生成 API 返回类型(gen-api-types)",
        "category": "Gen API Types"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "gen-api-types.generateApiTypes",
          "when": "resourceScheme == file && (resourceLangId == typescript || resourceLangId == typescriptreact)",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "gen-api-types.generateApiTypes",
          "when": "resourceScheme == file && resourceExtname =~ /\\.(ts|tsx)$/",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Gen API Types",
      "properties": {
        "gen-api-types.projectRoot": {
          "type": "string",
          "default": "",
          "description": "项目根目录。留空时使用当前 TypeScript 文件所在的工作区根目录。"
        },
        "gen-api-types.outputFile": {
          "type": "string",
          "default": "api-types.d.ts",
          "description": "传给 gen-api-types 的 -O/--output_file 输出文件名。"
        },
        "gen-api-types.outputDir": {
          "type": "string",
          "default": "",
          "description": "传给 gen-api-types 的 -o/--output_dir 输出目录。留空时使用当前 TypeScript 文件所在目录。"
        },
        "gen-api-types.tsConfigPath": {
          "type": "string",
          "default": "",
          "description": "传给 gen-api-types 的 -t/--ts_config_path tsconfig.json 文件路径。留空时使用项目根目录下的 tsconfig.json。"
        },
        "gen-api-types.isExported": {
          "type": "boolean",
          "default": false,
          "description": "是否传入 --isExported，生成导出的类型声明。"
        },
        "extension-template.webviewTitle": {
          "type": "string",
          "default": "Extension Template",
          "description": "Webview 面板标题示例配置。"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run webview:build && webpack",
    "watch": "webpack --watch",
    "webview:dev": "pnpm -C webview dev",
    "webview:build": "pnpm -C webview build",
    "package": "pnpm run webview:build && webpack --mode production --devtool hidden-source-map",
    "build": "mkdir -p release && vsce package --no-dependencies -o release/gen-api-types-vsce.vsix",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "publish": "vsce publish",
    "publish:major": "pnpm version major && pnpm run publish",
    "publish:minor": "pnpm version minor && pnpm run publish",
    "publish:patch": "pnpm version patch && pnpm run publish"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.70.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^9.25.1",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.3",
    "webpack": "^5.99.7",
    "webpack-cli": "^6.0.1"
  }
}